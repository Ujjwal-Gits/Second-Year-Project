# ── Dependencies ──────────────────────────────────────────
node_modules/
hamroyatra/client/node_modules/
hamroyatra/server/node_modules/

# ── Environment variables ──────────────────────────────────
.env
.env.local
.env.development
.env.production
hamroyatra/server/.env
hamroyatra/client/.env

# ── Build output ───────────────────────────────────────────
dist/
build/
hamroyatra/client/dist/

# ── Uploads (user-generated files) ────────────────────────
hamroyatra/server/uploads/*
!hamroyatra/server/uploads/.gitkeep

# ── Logs ──────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS files ──────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ── Debug scripts (server root) ───────────────────────────
hamroyatra/server/debug_*.js

# ── Markdown docs (not for repo) ──────────────────────────
*.md
!README.md

# ── Misc ──────────────────────────────────────────────────
.cache/
.parcel-cache/
coverage/
